{
 "suite": "numpy.indexing",
 "numpy_version": "2.0.2",
 "cases": [
  {
   "name": "at_1_2",
   "operation": "m[1, 2]",
   "expected": {
    "scalar": 5.0
   }
  },
  {
   "name": "negative_index",
   "operation": "m[-1, -1]",
   "expected": {
    "scalar": 5.0
   }
  },
  {
   "name": "slice_rows",
   "operation": "m[0:1]",
   "expected": {
    "shape": [
     1,
     3
    ],
    "data": [
     0.0,
     1.0,
     2.0
    ]
   }
  },
  {
   "name": "slice_cols",
   "operation": "m[:, 1:3]",
   "expected": {
    "shape": [
     2,
     2
    ],
    "data": [
     1.0,
     2.0,
     4.0,
     5.0
    ]
   }
  },
  {
   "name": "slice_step",
   "operation": "np.arange(10)[0:10:3]",
   "expected": {
    "shape": [
     4
    ],
    "data": [
     0.0,
     3.0,
     6.0,
     9.0
    ]
   }
  },
  {
   "name": "take_axis0",
   "operation": "np.take(m, [1, 0], 0)",
   "expected": {
    "shape": [
     2,
     3
    ],
    "data": [
     3.0,
     4.0,
     5.0,
     0.0,
     1.0,
     2.0
    ]
   }
  },
  {
   "name": "mask_gt_2",
   "operation": "m[m > 2]",
   "expected": {
    "shape": [
     3
    ],
    "data": [
     3.0,
     4.0,
     5.0
    ]
   }
  },
  {
   "name": "where_scalar",
   "operation": "np.where(m > 2, m, 0)",
   "expected": {
    "shape": [
     2,
     3
    ],
    "data": [
     0.0,
     0.0,
     0.0,
     3.0,
     4.0,
     5.0
    ]
   }
  },
  {
   "name": "where_arrays",
   "operation": "np.where(v > w/2, v, w)",
   "expected": {
    "shape": [
     3
    ],
    "data": [
     4.0,
     5.0,
     6.0
    ]
   }
  },
  {
   "name": "broadcast_to",
   "operation": "np.broadcast_to(v, (2,3))",
   "expected": {
    "shape": [
     2,
     3
    ],
    "data": [
     1.0,
     2.0,
     3.0,
     1.0,
     2.0,
     3.0
    ]
   }
  }
 ]
}
