{
 "suite": "numpy.hardening_v1001",
 "numpy_version": "2.0.2",
 "cases": [
  {
   "name": "take_repeated",
   "operation": "np.take with repeated indexes",
   "expected": {
    "shape": [
     4
    ],
    "data": [
     30.0,
     30.0,
     10.0,
     30.0
    ]
   }
  },
  {
   "name": "take_2d_axis0",
   "operation": "np.take(2d, [2, 0], axis=0)",
   "expected": {
    "shape": [
     2,
     4
    ],
    "data": [
     8.0,
     9.0,
     10.0,
     11.0,
     0.0,
     1.0,
     2.0,
     3.0
    ]
   }
  },
  {
   "name": "take_2d_axis1",
   "operation": "np.take(2d, [3, 1, 1], axis=1)",
   "expected": {
    "shape": [
     3,
     3
    ],
    "data": [
     3.0,
     1.0,
     1.0,
     7.0,
     5.0,
     5.0,
     11.0,
     9.0,
     9.0
    ]
   }
  }
 ]
}
