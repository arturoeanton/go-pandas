{
 "suite": "pandas.hardening_v1001",
 "pandas_version": "2.3.3",
 "cases": [
  {
   "name": "h_stack_with_na",
   "operation": "stack(future_stack=True) keeps NA",
   "expected": {
    "values": [
     1.0,
     null,
     null,
     4.0
    ]
   }
  },
  {
   "name": "h_pivot_fill_value",
   "operation": "pivot_table fill_value=0",
   "expected": {
    "columns": [
     "c",
     "feb",
     "jan"
    ],
    "rows": [
     [
      "AR",
      0.0,
      10.0
     ],
     [
      "BR",
      20.0,
      0.0
     ]
    ]
   }
  },
  {
   "name": "h_transform_with_na",
   "operation": "transform('count') with NA in group",
   "expected": {
    "values": [
     1,
     1,
     1
    ]
   }
  },
  {
   "name": "h_query_precedence",
   "operation": "query('a + b * c > 10') precedence",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      2.0,
      3.0,
      4.0
     ]
    ]
   }
  },
  {
   "name": "h_resample_allna_bucket",
   "operation": "resample('D').mean() with all-NA bucket",
   "expected": {
    "columns": [
     "date",
     "v"
    ],
    "rows": [
     [
      "2026-01-01",
      null
     ],
     [
      "2026-01-02",
      3.0
     ]
    ]
   }
  }
 ]
}
