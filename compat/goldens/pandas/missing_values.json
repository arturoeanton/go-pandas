{
 "suite": "pandas.missing_values",
 "pandas_version": "2.3.3",
 "cases": [
  {
   "name": "isna_frame",
   "operation": "df.isna()",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      false,
      false,
      false
     ],
     [
      true,
      false,
      false
     ],
     [
      false,
      true,
      false
     ],
     [
      true,
      true,
      true
     ]
    ]
   }
  },
  {
   "name": "dropna_any",
   "operation": "df.dropna()",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      1.0,
      "x",
      1.5
     ]
    ]
   }
  },
  {
   "name": "dropna_all",
   "operation": "df.dropna(how='all')",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      1.0,
      "x",
      1.5
     ],
     [
      null,
      "y",
      2.5
     ],
     [
      3.0,
      null,
      3.5
     ]
    ]
   }
  },
  {
   "name": "dropna_thresh_2",
   "operation": "df.dropna(thresh=2)",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      1.0,
      "x",
      1.5
     ],
     [
      null,
      "y",
      2.5
     ],
     [
      3.0,
      null,
      3.5
     ]
    ]
   }
  },
  {
   "name": "dropna_subset_a",
   "operation": "df.dropna(subset=['a'])",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      1.0,
      "x",
      1.5
     ],
     [
      3.0,
      null,
      3.5
     ]
    ]
   }
  },
  {
   "name": "fillna_map",
   "operation": "df.fillna({'a':0,'b':'?','c':0})",
   "expected": {
    "columns": [
     "a",
     "b",
     "c"
    ],
    "rows": [
     [
      1.0,
      "x",
      1.5
     ],
     [
      0.0,
      "y",
      2.5
     ],
     [
      3.0,
      "?",
      3.5
     ],
     [
      0.0,
      "?",
      0.0
     ]
    ]
   }
  },
  {
   "name": "notna_series",
   "operation": "df['a'].notna()",
   "expected": {
    "values": [
     true,
     false,
     true,
     false
    ]
   }
  }
 ]
}
